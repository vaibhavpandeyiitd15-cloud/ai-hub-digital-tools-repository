# Supabase via Vercel integration (Mumbai) — auto-synced to Vercel; pull locally with:
#   npx vercel env pull .env.local
#
# Runtime (app on Vercel):
POSTGRES_PRISMA_URL=""
# Migrations + seed (use direct / non-pooling URL):
POSTGRES_URL_NON_POOLING=""
# Fallback aliases (optional):
# DATABASE_URL=""
# POSTGRES_URL=""

# Admin (Phase 2)
ADMIN_PASSWORD="change-me"

# Email (Phase 3 — Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="aihub@unilever.com"

# Azure OpenAI (Phase 4 — chatbot)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""
# Optional API version (default: 2024-08-01-preview)
# AZURE_OPENAI_API_VERSION=""
