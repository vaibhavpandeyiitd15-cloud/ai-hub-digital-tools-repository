# Supabase via Vercel integration (Mumbai) — auto-synced to Vercel; pull locally with:
#   npx vercel env pull .env.local
#
# Runtime (app on Vercel):
POSTGRES_PRISMA_URL=""
# Migrations + seed (use direct / non-pooling URL):
POSTGRES_URL_NON_POOLING=""
# Fallback aliases (optional):
# DATABASE_URL=""
# POSTGRES_URL=""

# Admin (Phase 2)
ADMIN_PASSWORD="change-me"

# Email (Phase 3 — Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Desire Lab <aihub@unilever.com>"

# LLM provider: auto | groq | azure | fallback
# auto = Azure if configured, else Groq, else keyword fallback
LLM_PROVIDER="groq"

# Groq (free prototype — OpenAI-compatible)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_EMBEDDING_MODEL="nomic-embed-text-v1_5"

# Azure OpenAI (Unilever production target)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""
# Optional API version (default: 2024-08-01-preview)
# AZURE_OPENAI_API_VERSION=""
