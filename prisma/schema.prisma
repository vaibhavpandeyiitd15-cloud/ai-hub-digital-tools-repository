generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ToolStatus {
  ACTIVE
  BETA
  DEPRECATED
}

enum TrainingDocType {
  GUIDE
  VIDEO
  SLIDE_DECK
  FAQ
  OTHER
}

enum BookingStatus {
  PENDING
  CONTACTED
  COMPLETED
  CANCELLED
}

enum LabType {
  CONSUMER
  SCIENCE
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  lab         LabType  @default(CONSUMER)
  sortOrder   Int      @default(0)
  tools       Tool[]
  createdAt   DateTime @default(now())
}

model Tool {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  status        ToolStatus    @default(ACTIVE)
  purpose       String
  description   String        @db.Text
  toolUrl       String        @default("#")
  pocName       String        @default("TBD")
  pocEmail      String        @default("aihub@unilever.com")
  pocTeam       String?
  tags          String[]      @default([])
  prerequisites String?
  trainingDocs  TrainingDoc[]
  bookings      Booking[]
  lastUpdated   DateTime      @updatedAt
  createdAt     DateTime      @default(now())

  @@index([categoryId])
  @@index([status])
}

model TrainingDoc {
  id     String          @id @default(cuid())
  toolId String
  tool   Tool            @relation(fields: [toolId], references: [id], onDelete: Cascade)
  title  String
  url    String
  type   TrainingDocType @default(GUIDE)
}

model Booking {
  id              String        @id @default(cuid())
  toolId          String
  tool            Tool          @relation(fields: [toolId], references: [id], onDelete: Cascade)
  requesterName   String
  requesterEmail  String
  preferredDate   DateTime
  preferredTime   String
  durationMinutes Int
  subject         String
  message         String?       @db.Text
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  @@index([toolId])
  @@index([status])
}
